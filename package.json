{
  "name": "@launchapp/design-system",
  "version": "0.4.0",
  "workspaces": [
    ".",
    "apps/*",
    "packages/*"
  ],
  "description": "Radix UI based design system for LaunchApp",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchapp-dev/design-system.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./react": "./src/react/index.ts",
    "./svelte": "./src/svelte/index.ts",
    "./vue": "./src/vue/index.ts"
  },
  "files": [
    "dist",
    "src/react",
    "src/svelte",
    "src/vue"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup",
    "build:storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "generate-registry": "node scripts/generate-registry.mjs",
    "check-registry": "node scripts/generate-registry.mjs && git diff --exit-code registry.json || (echo 'registry.json is out of date — run pnpm generate-registry and commit the result' && exit 1)",
    "generate-vscode-snippets": "node scripts/generate-vscode-snippets.mjs",
    "fix-a11y": "node scripts/fix-a11y.mjs",
    "fix-a11y:approve": "node scripts/fix-a11y.mjs --interactive",
    "fix-a11y:auto": "node scripts/fix-a11y.mjs --fix",
    "lint": "biome lint src/ --reporter=summary",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "if [ -z \"$NODE_AUTH_TOKEN\" ]; then echo 'Skipping npm publish: NODE_AUTH_TOKEN not set. Add NPM_TOKEN secret to repo settings to enable publishing.'; exit 0; else changeset publish; fi",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "svelte": { "optional": true }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-focus-scope": "^1.1.8",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.511.0",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.72.0",
    "react-is": "^19.2.4",
    "react-resizable-panels": "^4.7.6",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@axe-core/react": "^4.11.1",
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "axe-core": "^4.11.1",
    "chromatic": "^15.3.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "next": "^16.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "vue": "^3.5.32"
  }
}
