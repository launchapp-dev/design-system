{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*",
        "../../src/*"
      ],
      "@launchapp/design-system": [
        "../../src/index.ts"
      ],
      "@ds/blocks": [
        "../../src/blocks/index.ts"
      ],
      "@ds/blocks/auth": [
        "../../src/blocks/auth/index.ts"
      ],
      "@ds/blocks/dashboard": [
        "../../src/blocks/dashboard/index.ts"
      ],
      "@ds/blocks/settings": [
        "../../src/blocks/settings/index.ts"
      ],
      "@ds/blocks/navigation": [
        "../../src/blocks/navigation/index.ts"
      ],
      "@ds/blocks/data": [
        "../../src/blocks/data/index.ts"
      ],
      "@ds/blocks/ecommerce": [
        "../../src/blocks/ecommerce/index.ts"
      ],
      "@ds/blocks/marketing": [
        "../../src/blocks/marketing/index.ts"
      ],
      "@ds/blocks/layout": [
        "../../src/blocks/layout/index.ts"
      ],
      "@ds/blocks/admin": [
        "../../src/blocks/admin/index.ts"
      ],
      "@ds/blocks/app": [
        "../../src/blocks/app/index.ts"
      ],
      "@ds/blocks/billing": [
        "../../src/blocks/billing/index.ts"
      ],
      "@ds/blocks/blog": [
        "../../src/blocks/blog/index.ts"
      ],
      "@ds/blocks/community": [
        "../../src/blocks/community/index.ts"
      ],
      "@ds/blocks/errors": [
        "../../src/blocks/errors/index.ts"
      ],
      "@ds/blocks/files": [
        "../../src/blocks/files/index.ts"
      ],
      "@ds/blocks/forms": [
        "../../src/blocks/forms/index.ts"
      ],
      "@ds/blocks/integrations": [
        "../../src/blocks/integrations/index.ts"
      ],
      "@ds/blocks/landing": [
        "../../src/blocks/landing/index.ts"
      ],
      "@ds/blocks/messaging": [
        "../../src/blocks/messaging/index.ts"
      ],
      "@ds/blocks/notifications": [
        "../../src/blocks/notifications/index.ts"
      ],
      "@ds/blocks/onboarding": [
        "../../src/blocks/onboarding/index.ts"
      ],
      "@ds/blocks/search": [
        "../../src/blocks/search/index.ts"
      ],
      "@ds/blocks/team": [
        "../../src/blocks/team/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
