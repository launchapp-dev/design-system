      "--la-primary": "196 13% 45%",
      "--la-primary-foreground": "192 100% 12%",
      "--la-secondary": "44 11% 88%",
      "--la-secondary-foreground": "192 100% 12%",
      "--la-muted": "192 100% 35%",
      "--la-muted-foreground": "44 11% 93%",
      "--la-accent": "45 100% 51%",
      "--la-accent-foreground": "192 100% 12%",
      "--la-destructive": "1 79% 45%",
      "--la-destructive-foreground": "44 11% 93%",
      "--la-border": "192 100% 25%",
      "--la-input": "192 100% 25%",
      "--la-ring": "45 100% 51%"
