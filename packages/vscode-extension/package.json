{
  "name": "@launchapp/vscode-design-system",
  "displayName": "LaunchApp Design System",
  "description": "VS Code extension providing component snippets, prop autocomplete, and design token preview for LaunchApp design system",
  "version": "0.1.0",
  "publisher": "launchapp",
  "license": "MIT",
  "author": {
    "name": "LaunchApp"
  },
  "homepage": "https://github.com/launchapp-dev/design-system#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/launchapp-dev/design-system.git"
  },
  "bugs": {
    "url": "https://github.com/launchapp-dev/design-system/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Programming Languages",
    "Themes",
    "Other"
  ],
  "keywords": [
    "design-system",
    "components",
    "snippets",
    "react",
    "typescript",
    "tailwind",
    "radix-ui",
    "autocomplete",
    "tokens"
  ],
  "icon": "icons/icon.png",
  "galleryBanner": {
    "color": "#f3f4f6",
    "theme": "light"
  },
  "contributes": {
    "snippets": [
      {
        "language": "typescriptreact",
        "path": "./snippets/components.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/imports.json"
      }
    ],
    "commands": [
      {
        "command": "launchapp-ds.insertComponent",
        "title": "Insert LaunchApp Component"
      },
      {
        "command": "launchapp-ds.previewToken",
        "title": "Preview Design Token"
      }
    ],
    "keybindings": [
      {
        "command": "launchapp-ds.insertComponent",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "launchapp-ds-explorer",
          "name": "LaunchApp Design System",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "activationEvents": [
    "onLanguage:typescriptreact",
    "onLanguage:typescript",
    "onLanguage:jsx",
    "onLanguage:javascript",
    "onCommand:launchapp-ds.insertComponent",
    "onCommand:launchapp-ds.previewToken",
    "onView:launchapp-ds-explorer"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --external:vscode --outfile=dist/extension.js --platform=node --target=es2020",
    "watch": "npm run build -- --watch",
    "package": "npm run build && vsce package --out vscode-design-system.vsix",
    "publish": "npm run package && vsce publish",
    "publish:pre": "npm run package && vsce publish --pre-release",
    "test-package": "npm run build && vsce package --out test-build.vsix && echo '✓ Package created successfully'",
    "clean": "rm -rf dist *.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "@launchapp/design-system": "workspace:*"
  }
}
